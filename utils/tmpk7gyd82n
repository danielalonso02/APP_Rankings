# Validación simple de usuario y clave con un archivo csv
def validarUsuario(usuario, clave):
    dfusuarios = pd.read_csv('usuarios.csv')
    return any((dfusuarios['usuario'] == usuario) & (dfusuarios['clave'] == clave))

