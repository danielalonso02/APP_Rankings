def extract_physical_percentiles(physical_filepath, parameters_file, player_id_analizing, min_minutes):
    if not os.path.exists(physical_filepath):
        return None
    
    df_phys = pd.read_excel(physical_filepath)
    
    # 1. Filtrar por minutos
    df_phys = df_phys[df_phys["Time Played"] > min_minutes].copy()
    
    if player_id_analizing not in df_phys["player_id"].values:
        return None

    # 2. Obtener posición para saber qué métricas físicas usar
    player_pos = df_phys.loc[df_phys["player_id"] == player_id_analizing, "position"].iloc[0]
    
    # 3. Leer métricas físicas del Excel de parámetros
    # (Asumiendo que añades una columna 'fisico' y 'fisico es' en tu parameters.xlsx)
    df_params = pd.read_excel(parameters_file, sheet_name=player_pos)
    phys_cols = df_params['fisico'].dropna().tolist()
    phys_labels = df_params['fisico es'].dropna().tolist()
    
    # 4. Calcular percentiles solo de la población de la misma posición
    df_pos = df_phys[df_phys["position"] == player_pos].copy()
    
    results = {}
    for col, label in zip(phys_cols, phys_labels):
        values = df_pos[col].values
        player_val = df_phys.loc[df_phys["player_id"] == player_id_analizing, col].iloc[0]
        # Calculamos percentil
        p_val = percentileofscore(values, player_val, kind='rank')
        results[label] = int(round(p_val))
        
    return results

